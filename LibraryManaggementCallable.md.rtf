delimiter $$\
\
create procedure InsertBook\
(\
    in p_id int,\
    in p_title varchar(50),\
    in p_author varchar(50),\
    in p_category varchar(30),\
    in p_price double\
)\
begin\
\
    insert into books\
    values\
    (\
        p_id,\
        p_title,\
        p_author,\
        p_category,\
        p_price\
    );\
\
end $$\
\
delimiter ;\
\
