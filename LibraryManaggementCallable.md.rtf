import java.sql.*;\
\
public class BookDAO \{\
\
    Connection con;\
\
    public BookDAO() throws Exception \{\
\
        Class.forName(\
        "com.mysql.cj.jdbc.Driver");\
\
        con =\
        DriverManager.getConnection(\
        "jdbc:mysql://localhost:3306/librarydb",\
        "root",\
        "root");\
    \}\
\
    public void insertBook(Book b)\
    throws Exception \{\
\
        CallableStatement cs =\
        con.prepareCall(\
        "\{call InsertBook(?,?,?,?,?)\}");\
\
        cs.setInt(1,b.getBookId());\
        cs.setString(2,b.getTitle());\
        cs.setString(3,b.getAuthor());\
        cs.setString(4,b.getCategory());\
        cs.setDouble(5,b.getPrice());\
\
        cs.executeUpdate();\
\
        System.out.println(\
        "Book Inserted Successfully");\
    \}\
\
    public void updatePrice(\
            int bookId,\
            double price)\
    throws Exception \{\
\
        CallableStatement cs =\
        con.prepareCall(\
        "\{call UpdateBookPrice(?,?)\}");\
\
        cs.setInt(1,bookId);\
        cs.setDouble(2,price);\
\
        cs.executeUpdate();\
\
        System.out.println(\
        "Price Updated");\
    \}\
\
    public void deleteBook(int bookId)\
    throws Exception \{\
\
        CallableStatement cs =\
        con.prepareCall(\
        "\{call DeleteBook(?)\}");\
\
        cs.setInt(1,bookId);\
\
        cs.executeUpdate();\
\
        System.out.println(\
        "Book Deleted");\
    \}\
\
    public void displayCategory(\
            String category)\
    throws Exception \{\
\
        CallableStatement cs =\
        con.prepareCall(\
        "\{call GetBooksByCategory(?)\}");\
\
        cs.setString(1,category);\
\
        ResultSet rs =\
        cs.executeQuery();\
\
        while(rs.next()) \{\
\
            System.out.println(\
            rs.getInt(1)+"  "+\
            rs.getString(2)+"  "+\
            rs.getString(3)+"  "+\
            rs.getString(4)+"  "+\
            rs.getDouble(5));\
        \}\
    \}\
\}\
\
